# =============================================================================
# stream-agent - Variables de entorno (Fase 1, solo lectura)
# Copiar a .env y ajustar:  cp .env.example .env
# =============================================================================

# --- Servicio ---
PORT=8090
LOG_LEVEL=info

# --- Autorización (HU 1.3) ---
# Token para los endpoints de diagnóstico (/cameras, /report, /diagnose, /run).
# Sin este valor, esos endpoints responden 503 (fail-closed).
# Uso: Authorization: Bearer <token>
AGENT_API_TOKEN=

# --- MediaMTX (red interna del compose) ---
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_HLS_URL=http://mediamtx:8888
MEDIAMTX_LOG_PATH=/shared-logs/mediamtx.log

# --- Gemini (se usa en la tarea de diagnóstico IA, HU 1.1) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Programación (ejecución automática, HU 1.2) ---
SCAN_INTERVAL_SECONDS=300

# --- Notificación (HU 1.2) ---
NOTIFY_CHANNEL=slack
SLACK_WEBHOOK_URL=

# --- Historial en el backend (HU 4.6) ---
# El agente persiste los diagnósticos vía POST/GET /admin/failures del backend.
# Sin ADMIN_API_TOKEN, el historial queda deshabilitado (notifica en cada corrida).
BACKEND_URL=http://mediamtx-backend:8080
ADMIN_API_TOKEN=
