# =============================================================================
# PRODUCCIÓN — plantilla de variables (HU 3.1)
# =============================================================================
# En la VM: copiar a  .env  (el que lee docker compose), rellenar y proteger:
#     cp .env.prod.example .env && chmod 600 .env
# NO versionar el .env real. Genera secretos NUEVOS (distintos de dev).
#
# Arranque en prod:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# =============================================================================

# --- Servidor / JWT ---
JWT_EXP_MINUTES=60
RUST_LOG=info

# --- Base de datos: Cloud SQL vía Auth Proxy ---
# INSTANCE_CONNECTION_NAME de tu instancia Cloud SQL (project:region:instance).
CLOUDSQL_INSTANCE=PROJECT:REGION:INSTANCE
# El backend conecta al proxy (host = cloudsql-proxy). Usuario/pass/db de Cloud SQL:
DATABASE_URL=postgres://USUARIO:PASSWORD@cloudsql-proxy:5432/NOMBRE_BD
# Clave AES-256-GCM de PRODUCCIÓN (NUEVA):  openssl rand -base64 32
DB_ENCRYPTION_KEY=

# --- Administración / reconciler ---
# Token admin de PRODUCCIÓN (NUEVO):  openssl rand -hex 32
ADMIN_API_TOKEN=
RECONCILE_INTERVAL_SECS=300

# --- Caddy / acceso público ---
# Subdominio que resuelve (DNS A) a la IP pública de la VM.
CADDY_SITE_ADDRESS=media.carmi.com
# Orígenes CORS permitidos (regex del header Origin del frontend).
# Ej: ^https://app\.carmi\.com$   (default '^$' = ninguno). En .env va SIN escapar el $.
CORS_ALLOWED_ORIGINS=^https://app\.carmi\.com$
RATE_LIMIT_EVENTS=120
RATE_LIMIT_WINDOW=1m

# --- Agente (comparte el token admin con el backend, vía compose) ---
BACKEND_URL=http://mediamtx-backend:8080
# Los secretos propios del agente (GEMINI_API_KEY, SLACK_WEBHOOK_URL, AGENT_API_TOKEN)
# van en  agent/.env  en la VM (ver agent/.env.example).
